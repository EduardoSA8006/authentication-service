PROJECT_NAME=Authentication Service
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
POSTGRES_DB=auth_service
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_ECHO=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Security
SECRET_KEY=change-me-in-production-use-a-random-64-char-string
ALLOWED_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]
TRUSTED_PROXY_IPS=["127.0.0.1","::1"]
POSTGRES_SSL=false
REDIS_TLS=false

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Session / Cookies
SESSION_TTL=604800
SESSION_IDLE_TTL=86400
TOKEN_ROTATION_INTERVAL=3600
TOKEN_ROTATION_GRACE=60
COOKIE_SECURE=false

# SMTP (defaults apontam pra mailhog em dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false
SMTP_FROM="Authentication Service <noreply@localhost>"
SMTP_TIMEOUT=15

# Frontend URL (obrigatório — onde está a página de verify-email)
FRONTEND_URL=http://localhost:3000
