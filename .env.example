# =============================================================================
# DEV-ONLY DEFAULTS — NÃO USE EM PRODUÇÃO
# -----------------------------------------------------------------------------
# Os valores abaixo foram escolhidos para facilitar "clone && docker compose up"
# em desenvolvimento local. NENHUM deles é seguro em produção:
#   - POSTGRES_PASSWORD=auth (credencial default conhecida)
#   - REDIS_PASSWORD=redis (credencial default conhecida)
#   - MINIO_ACCESS_KEY/SECRET_KEY=minioadmin (default do minio)
#   - SECRET_KEY é placeholder — deve ser 32+ bytes de secrets.token_urlsafe()
#   - COOKIE_SECURE=false (cookies sobre HTTP — só OK em localhost)
#   - ENVIRONMENT=development (desliga validações de produção)
#   - DEBUG=true (expõe /docs e traces)
#
# validate_settings_for_production() bloqueia startup em ENVIRONMENT=production
# se qualquer desses valores permanecer inseguro. Não dependa só disso: gere
# secrets fortes e materialize o .env de produção via secret manager
# (AWS Secrets Manager, GCP Secret Manager, Vault, doppler, etc).
# =============================================================================

PROJECT_NAME=Authentication Service
ENVIRONMENT=development
DEBUG=true

# PostgreSQL — DEV DEFAULTS
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
POSTGRES_DB=auth_service
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_ECHO=false

# Redis — DEV DEFAULTS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_DB=0

# MinIO — DEV DEFAULTS
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Security — PLACEHOLDER, SUBSTITUIR EM PRODUÇÃO
SECRET_KEY=change-me-in-production-use-a-random-64-char-string
ALLOWED_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]
TRUSTED_PROXY_IPS=["127.0.0.1","::1"]
POSTGRES_SSL=false
REDIS_TLS=false

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Session / Cookies — COOKIE_SECURE=true em produção (HTTPS obrigatório)
SESSION_TTL=604800
SESSION_IDLE_TTL=86400
TOKEN_ROTATION_INTERVAL=3600
TOKEN_ROTATION_GRACE=60
COOKIE_SECURE=false

# SMTP (defaults apontam pra mailhog em dev)
# Em produção, escolha UM modo de TLS:
#   - STARTTLS (porta 587, mais comum):   SMTP_TLS=true,  SMTP_IMPLICIT_TLS=false
#   - SMTPS implícito (porta 465):        SMTP_TLS=false, SMTP_IMPLICIT_TLS=true
# Os dois=true é rejeitado pelo validator de produção.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false
SMTP_IMPLICIT_TLS=false
SMTP_FROM="Authentication Service <noreply@localhost>"
SMTP_TIMEOUT=10

# Frontend URL (obrigatório — onde está a página de verify-email)
FRONTEND_URL=http://localhost:3000

# HaveIBeenPwned breach check (k-anonymity, externo)
HIBP_ENABLED=true
HIBP_TIMEOUT=3.0
# Opcional: email de contato incluído no User-Agent (recomendado em produção
# para que Cloudflare abuse-detection contate o operador antes de bloquear).
HIBP_CONTACT=

# CAPTCHA — step-up quando Layer 2 do lockout dispara.
# ENABLED=true é o default seguro; em prod o startup é bloqueado se estiver
# false (N-6 vira hard-block de 30min sem bypass pro usuário legítimo).
# Em dev, manter ENABLED=false evita dependência externa durante testes.
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET=
CAPTCHA_SITE_KEY=
CAPTCHA_VERIFY_TIMEOUT=5.0
